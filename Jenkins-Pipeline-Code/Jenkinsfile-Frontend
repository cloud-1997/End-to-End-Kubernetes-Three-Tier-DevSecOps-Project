pipeline {
    agent any 
    tools {
        nodejs 'NodeJs'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        AWS_ACCOUNT_ID = credentials('ACCOUNT_ID')
        AWS_ECR_REPO_NAME = credentials('ECR_REPO01')
        AWS_DEFAULT_REGION = 'us-east-2'
        REPOSITORY_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/"
    }
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout from Git') {
            steps {
                git credentialsId: 'GITHUB', 
                    branch: 'master', // Change to 'main' if your repository uses main
                    url: 'https://github.com/cloud-1997/End-to-End-Kubernetes-Three-Tier-DevSecOps-Project.git'
            }
        }
        stage('Sonarqube Analysis') {
            steps {
                dir('Application-Code/frontend') {
                    withSonarQubeEnv('sonar-server') {
                        // Using double quotes so Jenkins correctly expands $SCANNER_HOME
                        sh """
                            $SCANNER_HOME/bin/sonar-scanner \
                            -Dsonar.projectKey=three-tier-frontend \
                            -Dsonar.sources=. \
                            -Dsonar.host.url=http://3.137.149.119:9000 \
                            -Dsonar.login=squ_27eb2f8e9f39007152078ee47ada685264b2e14c
                        """
                    }
                }
            }
        }
        stage('Quality Check') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token' 
                }
            }
        }
        stage('Trivy File Scan') {
            steps {
                dir('Application-Code/frontend') {
                    sh 'trivy fs . > trivyfs.txt'
                }
            }
        }
        stage("Docker Image Build") {
            steps {
                script {
                    dir('Application-Code/frontend') {
                        sh 'docker system prune -f'
                        sh 'docker container prune -f'
                        // Changed to double quotes for variable expansion
                        sh "docker build -t ${AWS_ECR_REPO_NAME} ."
                    }
                }
            }
        }
        stage("ECR Image Pushing") {
            steps {
                script {
                    // Changed to double quotes for variable expansion
                    sh "aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${REPOSITORY_URI}"
                    sh "docker tag ${AWS_ECR_REPO_NAME} ${REPOSITORY_URI}${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}"
                    sh "docker push ${REPOSITORY_URI}${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}"
                }
            }
        }
        stage("TRIVY Image Scan") {
            steps {
                // Changed to double quotes for variable expansion
                sh "trivy image ${REPOSITORY_URI}${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} > trivyimage.txt" 
            }
        }
        stage('Update Deployment file') {
            environment {
                GIT_REPO_NAME = "End-to-End-Kubernetes-Three-Tier-DevSecOps-Project"
                GIT_USER_NAME = "cloud-1997"
            }
            steps {
                dir('Kubernetes-Manifests-file/Frontend') {
                    // Using usernamePassword to extract your token cleanly from your 'GITHUB' credential
                    withCredentials([usernamePassword(credentialsId: 'GITHUB', usernameVariable: 'GIT_USER', passwordVariable: 'GITHUB_TOKEN')]) {
                        sh '''
                            git config user.email "rohitbomman1997@gmail.com"
                            git config user.name "cloud-1997"
                            
                            # Safely parse out the current tag assigned to frontend
                            imageTag=$(grep -oP '(?<=frontend:)[^ ]+' deployment.yaml)
                            echo "Current image tag found: $imageTag"
                            
                            # Replace the tag with the current build number
                            sed -i "s/${AWS_ECR_REPO_NAME}:${imageTag}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}/" deployment.yaml
                            
                            git add deployment.yaml
                            git commit -m "Update frontend deployment Image to version ${BUILD_NUMBER}"
                            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:master
                        '''
                    }
                }
            }
        }
    }
}
